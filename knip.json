{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "ignoreExportsUsedInFile": {
        "interface": true,
        "type": true
    },
    "tags": [
        "-lintignore"
    ],
    "ignoreDependencies": [
    ],
    "entry": [
        "server.ts",
        "src/client.tsx",
        "src/router.tsx",
        "src/routeTree.gen.ts",
        "src/start.ts",
        "src/styles.css",
        "src/routes/**/*.{ts,tsx}"
    ],
    "project": [
        "src/**/*.{ts,tsx}"
    ],
    "vite": {
        "config": [
            "vite.config.ts"
        ]
    },
    "ignoreIssues": {
        "src/lib/utils/seed-database.ts": [
            "exports",
            "files"
        ],
        "src/lib/client/components/ui/**": [
            "exports",
            "files"
        ]
    }
}
